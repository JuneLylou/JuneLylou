        "/home/jbreton/.vscode/extensions/fxtd-odyssey.mayapy-1.0.4/mayaSDK",
        "/home/jbreton/Documents/packages/rig_sandbox_crossprod/python",
        "/home/jbreton/Documents/packages/rig_sandbox_vet/python"
